TELEGRAM_BOT_TOKEN=your_token_from_botfather
OLLAMA_BASE_URL=http://127.0.0.1:11434
# Одна модель на все этапы (ответ, анализ, ревью)
OLLAMA_MODEL_UNIFIED=mistral
# ollama pull nomic-embed-text
OLLAMA_EMBED_MODEL=nomic-embed-text
# Ваш Telegram user id (узнать через /myid)
ADMIN_TELEGRAM_ID=
# Источник знаний фиксирован: data/college_ai_knowledge (markdown-файлы)

# Семантический поиск: сколько фрагментов на подвопрос; порог косинуса (0–1), ниже — «не нашёл»
RAG_TOP_K=4
RAG_MIN_SIMILARITY=0.32
RAG_MIN_CONFIDENCE=0.38
RAG_MAX_CONTEXT_BLOCKS=2

# По умолчанию индексируется только knowledge (рекомендуется для точности)
RAG_ONLY_KNOWLEDGE=1
