TELEGRAM_BOT_TOKEN=your_token_from_botfather
OLLAMA_BASE_URL=http://127.0.0.1:11434
# Роутинг моделей:
# - быстрые ответы студентам
OLLAMA_MODEL_QUICK=phi3
# - объяснение тем
OLLAMA_MODEL_EXPLAIN=mistral
# - сложные вопросы
OLLAMA_MODEL_COMPLEX=llama3
# Вторая модель для проверки ответа LLM1 (LLM2)
# Можно оставить llama3 / mistral / другую стабильную модель.
OLLAMA_REVIEW_MODEL=llama3
# Legacy fallback (если уже используется в старом конфиге)
OLLAMA_MODEL=llama3.2
# ollama pull nomic-embed-text
OLLAMA_EMBED_MODEL=nomic-embed-text
# Ваш Telegram user id (узнать через /myid)
ADMIN_TELEGRAM_ID=
# Источник знаний фиксирован: data/college_ai_knowledge (markdown-файлы)

# Семантический поиск: сколько фрагментов на подвопрос; порог косинуса (0–1), ниже — «не нашёл»
RAG_TOP_K=4
RAG_MIN_SIMILARITY=0.32
RAG_MIN_CONFIDENCE=0.38
RAG_MAX_CONTEXT_BLOCKS=2

# По умолчанию индексируется только knowledge (рекомендуется для точности)
RAG_ONLY_KNOWLEDGE=1
